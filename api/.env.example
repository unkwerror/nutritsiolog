# Application
NODE_ENV=development
PORT=3001

# PostgreSQL
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/nutritsiolog

# Auth
# Minimum 32 characters, generate with: openssl rand -hex 32
JWT_SECRET=

# Redis (BullMQ)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# MinIO (S3-compatible storage)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=analyses

# OCR provider: gemini | mock | yandex
OCR_PROVIDER=gemini

# Gemini (required if OCR_PROVIDER=gemini)
GEMINI_API_KEY=

# SOCKS5 proxy for Gemini (required if OCR_PROVIDER=gemini, Gemini is blocked in Russia)
SOCKS_PROXY=socks5://127.0.0.1:1080

# Yandex (required if OCR_PROVIDER=yandex)
YANDEX_API_KEY=
YANDEX_FOLDER_ID=


# Admin access — comma-separated emails allowed into /api/v1/admin/*
# Доступ к админке привязан к почте. Пусто = админка недоступна никому.
ADMIN_EMAILS=

# CORS — frontend origin (Next.js dev: http://localhost:3000)
CORS_ORIGIN=http://localhost:3000

# Logging level: trace | debug | info | warn | error
LOG_LEVEL=info

# SMTP (email OTP)
# Dev: Mailpit на localhost:1025 (замена MailHog)
# Prod: SMTP вашего провайдера
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@nutritsiolog.local
# Prod: SMTP_HOST=smtp.yandex.ru, SMTP_PORT=465, SMTP_USER=noreply@domain.ru, SMTP_PASS=...
